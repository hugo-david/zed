{
	// === APPARENCE & THÈME ===
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Ayu Mirage"
	},
	"icon_theme": "Zed (Default)",

	// === POLICES & TYPOGRAPHIE ===
	"ui_font_size": 14.0,
	"ui_font_weight": 500.0,
	"buffer_font_size": 15.0,
	"buffer_font_weight": 500.0,
	// "buffer_font_family": "JetBrains Mono",
	// "ui_font_family": "JetBrains Mono",

	// === ÉDITEUR ===
	"tab_size": 2,
	"wrap_guides": [80],
	"show_wrap_guides": false,
	"show_whitespaces": "boundary",
	"auto_indent_on_paste": false,
	"base_keymap": "Cursor",

	// === ONGLETS ===
	"max_tabs": 6,
	"preview_tabs": {
		"enabled": false
	},
	"tab_bar": {
		"show": true,
		"show_nav_history_buttons": false
	},

	// === MINIMAP ===
	"minimap": {
		"show": "never"
	},

	// === SAUVEGARDE & FORMATAGE ===
	"autosave": "on_focus_change",
	"format_on_save": "on",
	"formatter": [
		{
			"code_action": "source.fixAll.biome"
		},
		{
			"code_action": "source.organizeImports.biome"
		},
		{
			"language_server": {
				"name": "biome"
			}
		}
	],
	"prettier": {
		"allowed": false
	},

	// === AUTOCOMPLÉTION & SUGGESTIONS ===
	"show_completions_on_input": true,
	"show_completion_documentation": true,
	"show_signature_help_after_edits": false,

	// === DIAGNOSTICS ===
	"diagnostics": {
		"button": true,
		"include_warnings": true,
		"inline": {
			"enabled": true,
			"update_debounce_ms": 150,
			"padding": 4,
			"min_column": 0,
			"max_severity": null
		}
	},

	// === LSP ===
	"lsp_document_colors": "background",
	"inlay_hints": {
		"edit_debounce_ms": 900
	},

	// === PRÉDICTIONS D'ÉDITION ===
	"features": {
		"edit_prediction_provider": "zed"
	},
	"edit_predictions": {
		"mode": "subtle"
	},

	// === AGENT IA ===
	"agent": {
		"default_profile": "write",
		"play_sound_when_agent_done": false,
		"always_allow_tool_actions": true,
		"default_model": {
			"provider": "zed.dev",
			"model": "claude-haiku-4-5"
		},
		"inline_assistant_model": {
			"model": "claude-haiku-4.5",
			"provider": "zed.dev"
		},
		"commit_message_model": {
			"model": "claude-haiku-4.5",
			"provider": "zed.dev"
		},
		"model_parameters": []
	},

	// === TERMINAL ===
	"terminal": {
		"dock": "bottom",
		"font_size": 15,
		"font_family": "CommitMono",
		"line_height": "standard"
	},

	// === EXTENSIONS ===
	"auto_update_extensions": {
		"biome": false
	},

	// === TÉLÉMÉTRIE ===
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	}
}
