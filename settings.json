{
	"agent": {
		"default_model": {
			"provider": "anthropic",
			"model": "claude-sonnet-4-5-latest"
		},
		"model_parameters": []
	},
	"preview_tabs": {
		"enabled": false
	},
	"format_on_save": "on",
	"autosave": "on_focus_change",
	"max_tabs": 6,
	"minimap": {
		"show": "auto"
	},
	"auto_indent_on_paste": false,
	"show_whitespaces": "boundary",
	"wrap_guides": [80],
	"tab_size": 2,
	"icon_theme": "Material Icon Theme",
	"base_keymap": "VSCode",
	"buffer_font_family": "CommitMono",
	"buffer_font_weight": 500,
	"ui_font_family": "CommitMono",
	"ui_font_size": 14,
	"buffer_font_size": 15.0,
	"terminal": {
		"dock": "bottom",
		"font_size": 15,
		"font_family": "CommitMono",
		"line_height": "standard"
	},
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "One Dark"
	},
	"features": {
		"edit_prediction_provider": "zed"
	},
	"formatter": {
		"language_server": {
			"name": "biome"
		}
	},
	"code_actions_on_format": {
		"source.fixAll.biome": true,
		"source.organizeImports.biome": true
	},
	"languages": {
		"JavaScript": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"TypeScript": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"TSX": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": false,
				"source.removeUnusedImports": true
			}
		}
	},
	"diagnostics": {
		"button": true,
		"include_warnings": true,
		"inline": {
			"enabled": true,
			"update_debounce_ms": 150,
			"padding": 4,
			"min_column": 0,
			"max_severity": null
		}
	}
}
